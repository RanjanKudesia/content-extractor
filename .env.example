APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

APP_NAME=Content Extractor

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=content_extractor
MONGODB_COLLECTION=extractions

# S3-compatible storage
S3_ENDPOINT_URL=https://your-s3-endpoint
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=us-east-1
S3_BUCKET_NAME=your-real-bucket-name
S3_KEY_PREFIX=content-extractor
S3_ADDRESSING_STYLE=path
S3_SIGNATURE_VERSION=s3v4
S3_SESSION_TOKEN=
